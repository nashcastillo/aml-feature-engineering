# --- Template .env (a copier en .env, jamais commit) ---
# Variables d'environnement pour le projet AML.
# Copie ce fichier vers .env, remplis les valeurs, ne le commit JAMAIS.

# Chemin local vers le dataset SAML-D (jamais dans le repo)
DATA_PATH=/absolute/path/to/SAML-D_sample_800k.csv

# Salt pour l'anonymisation SHA-256 des comptes
# Generer une chaine aleatoire 32+ caracteres : python -c "import secrets; print(secrets.token_hex(32))"
ANONYMIZATION_SALT=replace_with_a_long_random_string_32_chars_minimum

# Niveau de log pour la tracabilite (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# Repertoire de sortie pour les logs d'inferences (audit ACPR / Tracfin)
LOG_DIR=./logs
